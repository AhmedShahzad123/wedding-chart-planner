{
  "name": "wedding-chart-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "test:parser": "node scripts/test-parser.mjs",
    "test:templates": "node scripts/test-template-pagination.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "start": "cross-env NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/great-vibes": "^5.2.8",
    "@google/generative-ai": "^0.24.1",
    "@sparticuz/chromium": "^147.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "puppeteer-core": "^24.43.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vite": "^7.1.12"
  }
}
